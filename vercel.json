{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "pathowl.io" }],
      "destination": "https://app.pathowl.io/:path*",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.pathowl.io" }],
      "destination": "https://app.pathowl.io/:path*",
      "permanent": false
    }
  ]
}
